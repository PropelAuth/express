{
    "name": "@propelauth/express",
    "repository": {
        "type": "git",
        "url": "https://github.com/PropelAuth/express"
    },
    "version": "2.1.34",
    "license": "MIT",
    "keywords": [
        "auth",
        "express",
        "user"
    ],
    "dependencies": {
        "@propelauth/node": "^2.1.34"
    },
    "devDependencies": {
        "@propelauth/node-apis": "^2.1.34",
        "@rollup/plugin-commonjs": "^19.0.2",
        "@rollup/plugin-node-resolve": "^13.3.0",
        "@rollup/plugin-typescript": "^8.5.0",
        "@types/express": "^4.17.25",
        "@types/jest": "^27.5.2",
        "@types/jsonwebtoken": "^8.5.9",
        "@types/nock": "^11.1.0",
        "@types/uuid": "^8.3.4",
        "express": "^4.22.1",
        "jest": "^27.5.1",
        "jest-fetch-mock": "^3.0.3",
        "jsonwebtoken": "^9.0.3",
        "nock": "^13.5.6",
        "prettier": "^2.8.8",
        "prettier-plugin-organize-imports": "^2.3.4",
        "rimraf": "^3.0.2",
        "rollup": "^2.80.0",
        "rollup-plugin-peer-deps-external": "^2.2.4",
        "ts-jest": "^27.1.5",
        "tslib": "^2.8.1",
        "typescript": "^4.9.5",
        "uuid": "^8.3.2"
    },
    "scripts": {
        "type-check": "tsc --noEmit",
        "type-check:watch": "pnpm run type-check -- --watch",
        "build:types": "tsc --emitDeclarationOnly",
        "build:js": "rollup -c",
        "build": "pnpm run test && pnpm run build:types && pnpm run build:js",
        "test": "jest --silent",
        "prepublishOnly": "pnpm run build"
    },
    "main": "dist/index.js",
    "module": "dist/index.es.js",
    "files": [
        "dist"
    ],
    "jest": {
        "testMatch": [
            "**/test/*.ts"
        ],
        "moduleFileExtensions": [
            "ts",
            "js"
        ],
        "transform": {
            "^.+\\.(ts|tsx)?$": "ts-jest"
        },
        "setupFiles": [
            "./setupJest.js"
        ]
    }
}
